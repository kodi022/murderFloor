[internationalization]

locale/translations=PackedStringArray("res://translations/en_loot.en.translation", "res://translations/en_ui.en.translation")

[layer_names]

3d_render/layer_1="World"
3d_render/layer_2="Viewmodel"
3d_physics/layer_1="World"
3d_physics/layer_2="Character"
3d_physics/layer_3="Hitbox"
3d_physics/layer_4="Effects"
3d_physics/layer_5="Usable"
3d_physics/layer_6="Loot"

[navigation]

pathfinding/max_threads=6
3d/default_cell_size=0.1
3d/default_cell_height=0.1

[physics]

common/physics_ticks_per_second=100
common/max_physics_steps_per_frame=10
common/physics_jitter_fix=0.0
3d/physics_engine="Jolt Physics"
3d/solver/solver_iterations=8
common/physics_interpolation=true

[rendering]

rendering_device/vsync/swapchain_image_count=2
rendering_device/driver.windows="d3d12"
global_illumination/sdfgi/probe_ray_count=2
